{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MemoFlow",
  "version": "0.1.0",
  "identifier": "com.memoflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MemoFlow",
        "width": 650,
        "height": 420,
        "minWidth": 520,
        "minHeight": 360,
        "maxWidth": 1000,
        "maxHeight": 800,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
